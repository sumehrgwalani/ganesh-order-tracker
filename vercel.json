{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/sync-emails.ts": {
      "maxDuration": 300
    },
    "api/cron-sync.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron-sync",
      "schedule": "0 6 * * *"
    }
  ]
}
